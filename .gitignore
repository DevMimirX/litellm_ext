*.csv
*.tsv
*.csv.gz
*.csv.bz2
*.csv.xz
*.csv.zip
*.tsv.gz
*.tsv.bz2
*.tsv.xz
*.psv

# JSON lines & compressed JSON
*.jsonl
*.ndjson
*.json.gz
*.json.bz2
*.json.xz

# Spreadsheets
*.xlsx
*.xls
*.xlsb
*.xlsm
*.ods

# Databases
*.db
*.sqlite
*.sqlite3
*.duckdb
*.mdb
*.accdb

