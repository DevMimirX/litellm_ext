*.zip
*.gz
*.bz2
*.xz
*.zst
*.lz4
*.tar
*.tgz
*.tar.gz
*.tar.bz2
*.tar.xz
*.7z

# Spark / Hadoop output markers
part-*
_SUCCESS
_started*
_committed*
_metadata
_common_metadata
*.crc

# Delta Lake logs
**/_delta_log/


# =========================================
# Project-specific data & artifacts
# =========================================

# Ignore all files in datasets (Parquet/partition trees, metadata, etc.)
datasets/**

# Allow directory structure and gitkeeps inside datasets
!datasets/**/
!datasets/**/.gitkeep

# Keep small sample data in specific folders (unignore within these)
!tests/**/data/**
!tests/**/fixtures/**
!docs/**/assets/**
!examples/**/data/**
!examples/**/datasets/**


# -----------------------------------------
# Re-ignore Python bytecode even inside data/fixtures
# -----------------------------------------
**/__pycache__/
**/*.py[cod]
**/*$py.class


# =========================================
# ML / analytics artifacts (opt-in ignore)
# =========================================

mlruns/
wandb/
tensorboard/
ray_results/
dask-worker-space/
.claude/

